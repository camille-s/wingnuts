{
  "services": [
    {
      "name": "nominatim-api",
      "image": "mediagis/nominatim:5.1",
      "environment": {
        "SERVER_PORT": 8123,
        "PBF_URL": "${PBF_URL}",
        "REPLICATION_URL": "${REPLICATION_URL}",
        "NOMINATIM_PASSWORD_FILE": "/run/secrets/nominatim_key",
        "UPDATE_MODE": "catch-up",
        "IMPORT_STYLE": "full",
        "USER_UID": 1000,
        "USER_GID": 1000,
        "WARMUP_ON_STARTUP": 1
      },
      "internalPort": 8080,
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/nominatim/",
          "containerPath": "/var/lib/postgresql/16/main",
          "readOnly": false,
          "shared": false,
          "private": false
        }
      ],
      "shmSize": "128mb"
    },
    {
      "name": "nominatim-ui",
      "image": "ghcr.io/camille-s/nominatim-ui:0.1.0",
      "internalPort": 80,
      "isMain": true,
      "dependsOn": {
        "nominatim-api": {
          "condition": "service_started"
        }
      },
      "addPorts": [
        {
          "hostPort": 8189,
          "containerPort": 80
        }
      ]
    }
  ]
}
