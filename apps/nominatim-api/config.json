{
  "name": "Nominatim server",
  "id": "nominatim-api",
  "available": true,
  "short_desc": "Locally-hosted geocoding server",
  "author": "mediagis",
  "port": 8123,
  "categories": [
    "data"
  ],
  "description": "Nominatim uses OpenStreetMap data to find locations on Earth by name and address (geocoding). It can also do the reverse, find an address for any location on the planet. This app _does not_ include a debugging UI.",
  "tipi_version": 10,
  "version": "v5.3.2",
  "source": "https://github.com/mediagis/nominatim-docker",
  "exposable": true,
  "supported_architectures": [
    "arm64",
    "amd64"
  ],
  "created_at": 1753580424475,
  "updated_at": 1777423766000,
  "dynamic_config": true,
  "form_fields": [
    {
      "type": "url",
      "label": "URL to OSM data file",
      "hint": "See geofabrik.de for downloads; this is a *.osm.pbf file to download.",
      "default": "https://download.geofabrik.de/north-america/us/maryland-latest.osm.pbf",
      "required": true,
      "env_variable": "PBF_URL"
    },
    {
      "type": "url",
      "label": "Nominatim update file",
      "hint": "See geofabrik.de",
      "default": "https://download.geofabrik.de/north-america/us/maryland-updates/",
      "required": true,
      "env_variable": "REPLICATION_URL"
    },
    {
      "type": "text",
      "label": "User ID code",
      "default": "1000",
      "required": true,
      "env_variable": "USER_UID"
    },
    {
      "type": "text",
      "label": "Group ID code",
      "default": "1000",
      "required": true,
      "env_variable": "USER_GID"
    },
    {
      "type": "text",
      "label": "Update mode",
      "default": "catch-up",
      "required": true,
      "env_variable": "UPDATE_MODE"
    },
    {
      "type": "text",
      "label": "Import style",
      "default": "full",
      "required": true,
      "env_variable": "IMPORT_STYLE"
    },
    {
      "type": "boolean",
      "label": "Import Tiger addresses",
      "default": false,
      "required": false,
      "env_variable": "IMPORT_TIGER_ADDRESSES"
    }
  ]
}
